{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "MyDto",
  "title": "MyDto",
  "description": "Standard synchronous consumer message",
  "type": "object",
  "properties": {
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 125
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    }
  },
  "required": ["age", "firstName"]
}
