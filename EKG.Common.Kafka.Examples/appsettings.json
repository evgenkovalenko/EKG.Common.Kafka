{
  "kafka": {
    "config": {
      "base": {
        "bootstrap.servers": "localhost:9092"
      },
      "consumer": {
        "enable.auto.commit": true,
        "auto.commit.interval.ms": 1000,
        "statistics.interval.ms": 10000
      }
    },
    "producers": {
      "MyDto_Producer": {
        "topicName": "MyDto_Topic",
        "config": {
          "auto.offset.reset": "latest"
        }
      }
    },
    "consumers": {
      "MyDto_AsyncLoadingConsumer": {
        "topicName": "MyDto_Topic",
        "async": true,
        "config": {
          "auto.offset.reset": "earliest",
          "group.id": "[Guid]",
          "enable.partition.eof": true
        }
      },
      "MyDto_Consumer1": {
        "topicName": "MyDto_Topic",
        "config": {
          "auto.offset.reset": "earliest",
          "group.id": "MyDto_Consumer1"
        }
      },
      "MyDtoConsumerOverride": {
        "topicName": "MyDto_Topic",
        "config": {
          "auto.offset.reset": "earliest",
          "group.id": "MyDtoConsumerOverride.[HostName].[Guid]"
        }
      },
      "MyDtoProcessorEOF": {
        "topicName": "MyDto_Topic",
        "config": {
          "auto.offset.reset": "earliest",
          "group.id": "MyDtoProcessorEOF",
          "enable.partition.eof": true,
          "enable.auto.offset.store": false
        }
      },
      "MyDtoProcessorBatchingEOF": {
        "topicName": "MyDto_Topic",
        "config": {
          "auto.offset.reset": "earliest",
          "group.id": "MyDtoProcessorBatchingEOF",
          "enable.partition.eof": true,
          "enable.auto.offset.store": false
        }
      }
    }
  }
}
